---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import StubBody from "@/components/site/StubBody.astro";

const bullets = [
  "Anthropic blog (anthropic.com/news) — releases et updates Claude",
  "Latent Space (lspace.swyx.io) — interviews et deep dives IA",
  "Simon Willison's Weblog (simonwillison.net) — quotidien sur les outils LLM",
  "Every.to AI section — essais long-form sur l'IA et le travail",
  "Anthropic engineering blog — papers et architectures internes",
  "Filtre : pas d'AI-influencer générique, pas de regurgitation Twitter",
];

const sources = [
  { label: "Anthropic News", href: "https://www.anthropic.com/news" },
  { label: "Latent Space (Swyx)", href: "https://www.latent.space" },
  {
    label: "Simon Willison's Weblog",
    href: "https://simonwillison.net",
  },
  { label: "Every.to AI", href: "https://every.to/ai" },
];
---

<BaseLayout
  title="Learning"
  description="Les blogs et sites pour suivre Claude Code et l'IA — Anthropic, Latent Space, Simon Willison, Every.to."
>
  <PageHero
    eyebrow="04 · Learning"
    title="Sources curées pour suivre Claude"
    intro="Les blogs et sites qui valent vraiment le détour. Filtre exigeant : pas de fluff, pas de regurgitation. Mis à jour chaque semaine via le job batch."
  />

  <StubBody status="Curation en cours" bullets={bullets} sources={sources} />
</BaseLayout>
