---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import LearningCatalog from "@/components/site/LearningCatalog.vue";
import LatestNews from "@/components/site/LatestNews.astro";
import { learningEntries } from "@/data/learning";
---

<BaseLayout
  title="Learning"
  description="Sources curées pour suivre Claude Code et l'IA agentique — Anthropic, Simon Willison, Latent Space, Every, Hamel, Eugene Yan, Chip Huyen et plus."
>
  <PageHero
    eyebrow="04 · Learning"
    title="Sources curées pour suivre Claude"
    intro="Une sélection courte de blogs, newsletters et podcasts qui parlent vraiment de Claude Code, des agents et de l'AI engineering — pas des AI-influencers génériques."
  />

  <LatestNews />

  <section class="mx-auto max-w-6xl px-5 sm:px-8 py-12">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-claude mb-2">
      Catalogue des sources
    </p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-ink mb-3">
      Tous les blogs / newsletters / podcasts curés
    </h2>
    <p class="text-ink-muted leading-relaxed max-w-2xl mb-8 text-sm sm:text-base">
      Pour aller au-delà de l'aperçu live au-dessus : la liste complète
      des sources qu'on suit, triables par type et langue.
    </p>
    <LearningCatalog entries={learningEntries} client:load />

    <div
      class="mt-12 rounded-xl border border-claude/20 bg-claude/5 p-6 sm:p-8"
    >
      <p class="font-mono text-xs uppercase tracking-wider text-claude mb-3">
        Filtres de curation
      </p>
      <p class="text-ink leading-relaxed mb-3">
        Ce qui passe le filtre :
        <strong class="text-ink">contenu original</strong>,
        <strong class="text-ink">spécifique au tooling Claude / agents IA</strong>
        (pas de ML générique 2018), et
        <strong class="text-ink">à jour</strong> (le batch hebdo retirera
        les sources qui n'ont pas publié depuis 6+ mois — sauf exceptions
        comme Jay Alammar dont les illustrated guides sont des références
        gelées mais toujours utiles).
      </p>
      <p class="text-ink-muted leading-relaxed text-sm">
        Une source pertinente manquante ? Ouvre une issue
        <a
          href="https://github.com/Sylad/claude-code-codex/issues"
          target="_blank"
          rel="noopener"
          class="text-claude hover:text-claude-soft underline underline-offset-4"
          >sur le repo</a
        >.
      </p>
    </div>
  </section>
</BaseLayout>
