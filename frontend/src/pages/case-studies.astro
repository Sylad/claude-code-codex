---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import { testedTools } from "@/data/tools-tested";
import {
  STATUS_LABELS,
  STATUS_ACCENTS,
  STATUS_DOTS,
  CATEGORY_LABELS,
} from "@/data/tools-tested-types";
import type { ToolStatus } from "@/data/tools-tested-types";

const STATUS_ORDER: ToolStatus[] = ["tested", "to-test", "browsed"];
const groupedTools = STATUS_ORDER.map((status) => ({
  status,
  tools: testedTools.filter((t) => t.status === status),
}));

const totalTools = testedTools.length;

function formatStars(n?: number): string {
  if (!n) return "";
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return String(n);
}

const apps = [
  {
    name: "warhammer40k",
    tagline: "Codex narratif sur l'univers Warhammer 40K",
    stack: "Angular 19 · NestJS · Anthropic SDK",
    role: "Visual-first, lore consolidé, galaxy map Bézier",
    href: "/case-studies/warhammer40k",
    repo: "https://github.com/Sylad/warhammer40k",
    accent: "from-amber-500/20 to-transparent",
  },
  {
    name: "finance-tracker",
    tagline: "Tracker finances perso avec analyse PDF par Claude",
    stack: "React · NestJS · Claude tool_use two-phase",
    role: "Upload multi-PDF, catégorisation auto, démo Cloudflare verrouillée",
    href: "/case-studies/finance-tracker",
    repo: "https://github.com/Sylad/finance-tracker",
    accent: "from-emerald-500/20 to-transparent",
  },
  {
    name: "ol-companion",
    tagline: "Compagnon OL avec live-match et carte Ligue 1",
    stack: "React · NestJS · 365scores API · SSE",
    role: "Live SSE, brackets coupe, carte L1 markers bicolores",
    href: "/case-studies/ol-companion",
    repo: "https://github.com/Sylad/ol-companion",
    accent: "from-red-500/20 to-transparent",
  },
  {
    name: "avatar-pandora",
    tagline: "Codex Avatar / Pandora — atmosphère temps-driven",
    stack: "Astro 6 · React 19 · R3F · GSAP",
    role: "Cinema canvas time-driven, particules WebGL, ambient self-running",
    href: "/case-studies/avatar-pandora",
    repo: "https://github.com/Sylad/avatar-pandora",
    accent: "from-cyan-500/20 to-transparent",
  },
  {
    name: "evatosorus",
    tagline: "Codex paléonto richement illustré",
    stack: "Astro 6 · React 19 · openart.ai assets",
    role: "Hero T-Rex IA, vidéos boucle, codex 200+ espèces",
    href: "/case-studies/evatosorus",
    repo: "https://github.com/Sylad/evatosorus",
    accent: "from-lime-500/20 to-transparent",
  },
  {
    name: "claude-code-codex",
    tagline: "Ce site même — méta-codex sur Claude Code",
    stack: "Astro 6 · Vue 3 · shadcn-vue · GitHub Actions cron",
    role: "Doc + écosystème + case studies, batch update hebdo via Claude",
    href: "/case-studies/claude-code-codex",
    repo: "https://github.com/Sylad/claude-code-codex",
    accent: "from-orange-500/20 to-transparent",
  },
  {
    name: "aetherwx",
    tagline: "AetherWX — atlas live multi-source : AIS + météo + foudre + alerts (anciennement Maritime Atlas)",
    stack: "Angular 19 · NestJS 11 · GeoServer cluster · TimescaleDB · RabbitMQ",
    role: "5 sources externes, slider temps, particules canvas, cluster GeoServer JDBCConfig",
    href: "/case-studies/maritime-atlas",
    repo: "https://github.com/Sylad/maritime-atlas",
    accent: "from-teal-500/20 to-transparent",
  },
];
---

<BaseLayout
  title="Case studies"
  description="Sept apps codées en pair-programming avec Claude Code. Stack, archi, learnings."
>
  <PageHero
    eyebrow="03 · Case studies"
    title="Sept apps construites avec Claude Code"
    intro="Six projets perso + ce site lui-même. Tous codés en pair-programming avec Claude Code — 0 ligne de code écrite par l'humain. Clique sur une card pour le deep dive : architecture, stack, process IA, lessons learned."
  />

  <section class="mx-auto max-w-6xl px-5 sm:px-8 py-16">
    <div class="grid gap-5 sm:grid-cols-2">
      {apps.map((app) => (
        <article
          class={`group relative overflow-hidden rounded-xl border border-white/10 bg-paper-elevated p-6 hover:border-claude/40 transition-colors motion-safe:hover:-translate-y-0.5 motion-safe:hover:shadow-lg motion-safe:hover:shadow-claude/10`}
        >
          <div
            class={`absolute inset-0 bg-gradient-to-br ${app.accent} opacity-50 group-hover:opacity-80 transition-opacity pointer-events-none`}
          >
          </div>
          <div class="relative">
            <div class="flex items-center justify-between mb-3">
              <p class="font-mono text-sm text-claude">{app.name}</p>
              <a
                href={app.href}
                aria-label={`Deep dive ${app.name}`}
                class="text-ink-muted hover:text-claude motion-safe:hover:translate-x-1 transition-all"
              >
                →
              </a>
            </div>
            <h2 class="text-xl font-medium text-ink mb-2">
              <a
                href={app.href}
                class="hover:text-claude transition-colors"
              >
                {app.tagline}
              </a>
            </h2>
            <p class="text-sm text-ink-muted mb-4 leading-relaxed">
              {app.role}
            </p>
            <p class="font-mono text-xs text-ink/60 pt-3 border-t border-white/5 mb-3">
              {app.stack}
            </p>
            <div class="flex flex-wrap items-center gap-2">
              <a
                href={app.href}
                class="font-mono text-[10px] uppercase tracking-wider text-claude/80 hover:text-claude transition-colors"
              >
                Deep dive →
              </a>
              <a
                href={app.repo}
                target="_blank"
                rel="noopener"
                class="ml-auto font-mono text-[10px] uppercase tracking-wider text-ink-muted hover:text-claude transition-colors"
              >
                ↗ GitHub
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-16 mb-16">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-claude mb-2">
        Récits transverses
      </p>
      <h2 class="text-2xl sm:text-3xl font-semibold text-ink mb-3">
        Migrations & deep dives
      </h2>
      <p class="text-ink-muted leading-relaxed max-w-2xl mb-8">
        Articles qui couvrent plusieurs apps ou racontent un chantier
        d'infrastructure transverse. Format narratif, avec pièges
        techniques et leçons.
      </p>
      <div class="grid gap-5 sm:grid-cols-2">
        <article class="group relative overflow-hidden rounded-xl border border-white/10 bg-paper-elevated p-6 hover:border-claude/40 transition-colors motion-safe:hover:-translate-y-0.5 motion-safe:hover:shadow-lg motion-safe:hover:shadow-claude/10">
          <div class="absolute inset-0 bg-gradient-to-br from-violet-500/20 to-transparent opacity-50 group-hover:opacity-80 transition-opacity pointer-events-none"></div>
          <div class="relative">
            <p class="font-mono text-sm text-claude mb-3">k8s-migration-overnight</p>
            <h3 class="text-xl font-medium text-ink mb-2">
              <a href="/case-studies/k8s-migration-overnight" class="hover:text-claude transition-colors">
                La nuit où on est passé de Swarm à K8s
              </a>
            </h3>
            <p class="text-sm text-ink-muted mb-4 leading-relaxed">
              5 apps perso migrées d'un Docker Swarm sur NAS vers k3s
              local + GitOps complet via ArgoCD, en une nuit (13→14 mai
              2026). 7 pièges techniques documentés (ingress hostNetwork,
              CNPG webhook, JDBCConfig hardcode, plugins custom Java…),
              5 leçons, 1 repo public.
            </p>
            <p class="font-mono text-xs text-ink/60 pt-3 border-t border-white/5 mb-3">
              k3s · Helm · ArgoCD · CloudNativePG · RabbitMQ Operator · KEDA · cert-manager · GeoServer cluster
            </p>
            <div class="flex flex-wrap items-center gap-2">
              <a href="/case-studies/k8s-migration-overnight" class="font-mono text-[10px] uppercase tracking-wider text-claude/80 hover:text-claude transition-colors">
                Lire le récit →
              </a>
              <a href="https://github.com/Sylad/developpeur-gitops" target="_blank" rel="noopener" class="ml-auto font-mono text-[10px] uppercase tracking-wider text-ink-muted hover:text-claude transition-colors">
                ↗ Repo GitOps
              </a>
            </div>
          </div>
        </article>

        <article class="group relative overflow-hidden rounded-xl border border-white/10 bg-paper-elevated p-6 hover:border-claude/40 transition-colors motion-safe:hover:-translate-y-0.5 motion-safe:hover:shadow-lg motion-safe:hover:shadow-claude/10">
          <div class="absolute inset-0 bg-gradient-to-br from-teal-500/20 to-transparent opacity-50 group-hover:opacity-80 transition-opacity pointer-events-none"></div>
          <div class="relative">
            <p class="font-mono text-sm text-claude mb-3">aetherwx-encyclopedia</p>
            <h3 class="text-xl font-medium text-ink mb-2">
              <a href="/case-studies/aetherwx-encyclopedia" class="hover:text-claude transition-colors">
                L'encyclopédie AetherWX
              </a>
            </h3>
            <p class="text-sm text-ink-muted mb-4 leading-relaxed">
              Récit-tour pour développeurs Java qui débarquent sur K8s :
              archi dual-cluster Big-Blue + Mini-Blue, 17 services
              expliqués, <strong>6 tokens inventoriés</strong> (PAT
              GHCR, webhook ArgoCD, tunnel Cloudflare, Google OAuth,
              Resend, Anthropic), 5 leçons qui ont coûté 6h. 4 diagrammes
              Mermaid, table de traduction Spring Boot ↔ K8s.
            </p>
            <p class="font-mono text-xs text-ink/60 pt-3 border-t border-white/5 mb-3">
              k3s dual-cluster · GHCR · GH Actions · ArgoCD webhook · Longhorn RWX · Cloudflare Tunnel HA
            </p>
            <div class="flex flex-wrap items-center gap-2">
              <a href="/case-studies/aetherwx-encyclopedia" class="font-mono text-[10px] uppercase tracking-wider text-claude/80 hover:text-claude transition-colors">
                Lire l'encyclopédie →
              </a>
              <a href="/case-studies/maritime-atlas" class="ml-auto font-mono text-[10px] uppercase tracking-wider text-ink-muted hover:text-claude transition-colors">
                Vue fonctionnelle →
              </a>
            </div>
          </div>
        </article>

        <article class="group relative overflow-hidden rounded-xl border border-white/10 bg-paper-elevated p-6 hover:border-claude/40 transition-colors motion-safe:hover:-translate-y-0.5 motion-safe:hover:shadow-lg motion-safe:hover:shadow-claude/10">
          <div class="absolute inset-0 bg-gradient-to-br from-amber-500/20 to-transparent opacity-50 group-hover:opacity-80 transition-opacity pointer-events-none"></div>
          <div class="relative">
            <p class="font-mono text-sm text-claude mb-3">token-optimizers-2026</p>
            <h3 class="text-xl font-medium text-ink mb-2">
              <a href="/case-studies/token-optimizers-2026" class="hover:text-claude transition-colors">
                Token-optimizers landscape 2026
              </a>
            </h3>
            <p class="text-sm text-ink-muted mb-4 leading-relaxed">
              Bench de <strong>8 outils</strong> d'optimisation tokens
              Claude Code (MCP, plugins, CLI, CLAUDE.md files) en mai
              2026. 3 adoptés (RTK + code-review-graph + token-savior),
              2 piqués sans adopter (drona23 7 règles, nadimtuhin
              .claudeignore), 3 écartés (license PolyForm, deps externes,
              double-up). 5 méta-leçons sur le screening écosystème.
            </p>
            <p class="font-mono text-xs text-ink/60 pt-3 border-t border-white/5 mb-3">
              RTK · code-review-graph · drona23 · nadimtuhin · ooples · zilliz · Mibayy · alexgreensh
            </p>
            <div class="flex flex-wrap items-center gap-2">
              <a href="/case-studies/token-optimizers-2026" class="font-mono text-[10px] uppercase tracking-wider text-claude/80 hover:text-claude transition-colors">
                Lire le bench →
              </a>
            </div>
          </div>
        </article>
      </div>
    </div>

    <div class="mt-16">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-claude mb-2">
        Tools tested · {totalTools} entrées
      </p>
      <h2 class="text-2xl sm:text-3xl font-semibold text-ink mb-3">
        Outils explorés sur le banc d'essai
      </h2>
      <p class="text-ink-muted leading-relaxed max-w-2xl mb-8">
        Le codex sert aussi de banc d'essai personnel : on installe les outils
        de l'écosystème Claude Code, on les pousse en sandbox, et on capture
        les leçons — adoptés ou non. <strong class="text-ink">Testé</strong> =
        passé par la sandbox + case study écrit.
        <strong class="text-ink">À tester</strong> = identifié comme
        candidat. <strong class="text-ink">Sur le radar</strong> = repéré, à
        explorer si pertinent.
      </p>

      {groupedTools.map(({ status, tools }) => (
        tools.length > 0 && (
          <div class="mb-10">
            <div class="flex items-center gap-2 mb-4">
              <span
                class={`inline-block w-2 h-2 rounded-full ${STATUS_DOTS[status]}`}
              ></span>
              <h3 class="font-mono text-xs uppercase tracking-wider text-ink-muted">
                {STATUS_LABELS[status]} · {tools.length}
              </h3>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {tools.map((tool) => {
                const primaryHref = tool.caseStudyHref ?? tool.url;
                const isInternal = !!tool.caseStudyHref;
                return (
                  <article
                    class={`relative overflow-hidden rounded-xl border ${STATUS_ACCENTS[status]} p-5 transition-colors hover:border-claude/40 motion-safe:hover:-translate-y-0.5 motion-safe:hover:shadow-lg motion-safe:hover:shadow-claude/10`}
                  >
                    <div class="flex flex-col gap-3 h-full">
                      <div class="flex items-start justify-between gap-2">
                        <div class="min-w-0 flex-1">
                          <p class="font-mono text-[10px] uppercase tracking-wider text-claude">
                            {CATEGORY_LABELS[tool.category]}
                            {tool.stars && (
                              <span class="text-ink-muted ml-2">
                                ★ {formatStars(tool.stars)}
                              </span>
                            )}
                          </p>
                          <h4 class="mt-1 text-base font-medium text-ink truncate">
                            <a
                              href={primaryHref}
                              target={isInternal ? undefined : "_blank"}
                              rel={isInternal ? undefined : "noopener"}
                              class="hover:text-claude transition-colors"
                            >
                              {tool.name}
                            </a>
                          </h4>
                          <p class="mt-0.5 text-xs text-ink-muted">
                            {tool.author}
                            {tool.license && (
                              <span class="text-ink/50"> · {tool.license}</span>
                            )}
                          </p>
                        </div>
                      </div>

                      <p class="text-sm text-ink-muted leading-relaxed flex-1">
                        {tool.description}
                      </p>

                      <div class="flex flex-wrap items-center gap-2 pt-1">
                        {tool.caseStudyHref ? (
                          <a
                            href={tool.caseStudyHref}
                            class="font-mono text-[10px] uppercase tracking-wider text-claude/80 hover:text-claude transition-colors"
                          >
                            → Case study
                          </a>
                        ) : (
                          <span class="font-mono text-[10px] uppercase tracking-wider text-ink/40">
                            {tool.lastPush}
                          </span>
                        )}
                        <a
                          href={tool.url}
                          target="_blank"
                          rel="noopener"
                          class="ml-auto font-mono text-[10px] uppercase tracking-wider text-ink-muted hover:text-claude transition-colors"
                        >
                          ↗ GitHub
                        </a>
                      </div>
                    </div>
                  </article>
                );
              })}
            </div>
          </div>
        )
      ))}

      <div
        class="rounded-xl border border-white/5 border-dashed bg-paper-elevated/50 p-5 text-center"
      >
        <p class="font-mono text-xs uppercase tracking-wider text-ink/40 mb-1">
          Suggestion ?
        </p>
        <p class="text-ink-muted text-sm leading-relaxed">
          Une ressource Claude Code-spécifique mérite d'être ajoutée à la
          watchlist ? Ouvre une issue
          <a
            href="https://github.com/Sylad/claude-code-codex/issues"
            target="_blank"
            rel="noopener"
            class="text-claude hover:text-claude-soft underline underline-offset-4"
            >sur le repo</a
          >.
        </p>
      </div>
    </div>

  </section>
</BaseLayout>
