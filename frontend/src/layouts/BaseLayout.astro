---
import "@/styles/global.css";
import Navbar from "@/components/site/Navbar.vue";
import Footer from "@/components/site/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const fullTitle = title === "claude-code-codex"
  ? title
  : `${title} · claude-code-codex`;
const meta = description ?? "Codex non-officiel sur Claude Code : théorie, écosystème, case studies, ressources et vidéos.";
const pathname = Astro.url.pathname;
const canonical = new URL(pathname, Astro.url);
const ogImage = new URL("/og.svg", Astro.url).toString();
const heroPoster = "/hero-cyberpunk.jpg";
const heroVideo = "/hero-cyberpunk.mp4";
---

<!doctype html>
<html lang="fr" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={meta} />
    <link rel="canonical" href={canonical.toString()} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={meta} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="claude-code-codex — codex non-officiel sur Claude Code" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={meta} />
    <meta name="twitter:image" content={ogImage} />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <title>{fullTitle}</title>
  </head>
  <body class="text-ink min-h-dvh flex flex-col">
    <div
      class="fixed inset-0 -z-10 overflow-hidden pointer-events-none"
      aria-hidden="true"
    >
      <img
        src={heroPoster}
        alt=""
        class="absolute inset-0 w-full h-full object-cover object-center opacity-25"
      />
      <img
        src="/hero-cyberpunk-effects.svg"
        alt=""
        class="absolute inset-0 w-full h-full object-cover object-center opacity-70 mix-blend-screen"
      />
      <div
        class="absolute inset-0 bg-gradient-to-b from-paper/30 via-paper/65 to-paper/95"
      >
      </div>
    </div>
    <Navbar client:load pathname={pathname} />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>
