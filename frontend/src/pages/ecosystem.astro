---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import EcosystemCatalog from "@/components/site/EcosystemCatalog.vue";
import { ecosystemEntries } from "@/data/ecosystem";
---

<BaseLayout
  title="Écosystème"
  description="Catalogue triable de plugins, MCP servers, skills et SDKs Claude Code — sources officielles Anthropic uniquement."
>
  <PageHero
    eyebrow="02 · Écosystème"
    title="Plugins, MCP, skills, SDKs"
    intro="Catalogue des composants officiels (Anthropic + protocole MCP) que tu peux installer pour étendre Claude Code. Filtre par catégorie, recherche, et copie la commande d'install d'un clic."
  />

  <section class="mx-auto max-w-6xl px-5 sm:px-8 py-12">
    <EcosystemCatalog entries={ecosystemEntries} client:load />

    <div
      class="mt-12 rounded-xl border border-claude/20 bg-claude/5 p-6 sm:p-8"
    >
      <p class="font-mono text-xs uppercase tracking-wider text-claude mb-3">
        Critères du catalogue
      </p>
      <p class="text-ink leading-relaxed mb-3">
        Le cœur du catalogue est constitué d'entrées
        <strong class="text-ink">officielles Anthropic</strong>
        (marketplace
        <a
          href="https://github.com/anthropics/claude-plugins-official"
          target="_blank"
          rel="noopener"
          class="text-claude hover:text-claude-soft underline underline-offset-4"
          >claude-plugins-official</a
        >, dépôt
        <a
          href="https://github.com/anthropics/skills"
          target="_blank"
          rel="noopener"
          class="text-claude hover:text-claude-soft underline underline-offset-4"
          >anthropics/skills</a
        >, serveurs MCP de référence
        <a
          href="https://github.com/modelcontextprotocol/servers"
          target="_blank"
          rel="noopener"
          class="text-claude hover:text-claude-soft underline underline-offset-4"
          >modelcontextprotocol/servers</a
        >, SDK officiels, protocole MCP).
      </p>
      <p class="text-ink-muted leading-relaxed mb-3">
        Quelques projets <strong class="text-ink">tiers vetted</strong>
        sont également listés quand ils étendent significativement Claude
        Code (open-source, maintenus, écosystème Claude Code spécifique).
        Bascule le toggle « Anthropic-officiel uniquement » pour les
        masquer si tu veux du strict.
      </p>
      <p class="text-ink-muted leading-relaxed text-sm">
        Si tu vois manquer un composant intéressant, ouvre une issue
        <a
          href="https://github.com/Sylad/claude-code-codex/issues"
          target="_blank"
          rel="noopener"
          class="text-claude hover:text-claude-soft underline underline-offset-4"
          >sur le repo</a
        >.
      </p>
    </div>
  </section>
</BaseLayout>
