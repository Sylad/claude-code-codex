---
interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<section class="relative codex-grid border-b border-white/5">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-28">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-claude">
      {eyebrow}
    </p>
    <h1 class="mt-3 text-4xl sm:text-5xl font-semibold tracking-tight text-ink">
      {title}
    </h1>
    {intro && (
      <p class="mt-5 max-w-2xl text-base sm:text-lg text-ink-muted leading-relaxed">
        {intro}
      </p>
    )}
  </div>
</section>
