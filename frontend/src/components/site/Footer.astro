---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-white/5">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-10 grid gap-6 md:grid-cols-3 text-sm text-ink-muted">
    <div>
      <p class="font-mono text-ink">claude-code-codex</p>
      <p class="mt-1.5 text-xs">
        Codex non-officiel sur Claude Code, l'écosystème Anthropic et
        la collab IA × dev.
      </p>
    </div>

    <div class="flex flex-col gap-1">
      <p class="text-xs uppercase tracking-wider text-ink/60 mb-1">Ressources</p>
      <a class="hover:text-ink transition-colors" href="/theory">Théorie</a>
      <a class="hover:text-ink transition-colors" href="/ecosystem">Écosystème</a>
      <a class="hover:text-ink transition-colors" href="/learning">Learning</a>
      <a class="hover:text-ink transition-colors" href="/videos">Vidéos</a>
    </div>

    <div class="flex flex-col gap-1 md:items-end">
      <p class="text-xs uppercase tracking-wider text-ink/60 mb-1">Liens</p>
      <a
        class="hover:text-ink transition-colors"
        href="https://claude.com/claude-code"
        target="_blank"
        rel="noopener"
      >
        Claude Code (Anthropic)
      </a>
      <a
        class="hover:text-ink transition-colors"
        href="https://github.com/Sylad/claude-code-codex"
        target="_blank"
        rel="noopener"
      >
        Repo GitHub
      </a>
      <a class="hover:text-ink transition-colors" href="/about">À propos</a>
    </div>
  </div>

  <div class="border-t border-white/5">
    <div
      class="mx-auto max-w-6xl px-5 sm:px-8 py-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 text-xs text-ink-muted"
    >
      <p>
        © {year} — codex fan-site, sans affiliation officielle avec
        Anthropic.
      </p>
      <p class="font-mono">
        vibe coded with
        <a
          class="text-claude hover:text-claude-soft transition-colors"
          href="https://claude.com/claude-code"
          target="_blank"
          rel="noopener"
        >
          Claude Code
        </a>
      </p>
    </div>
  </div>
</footer>
