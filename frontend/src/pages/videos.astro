---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import VideosCatalog from "@/components/site/VideosCatalog.vue";
import { videoEntries } from "@/data/videos";
---

<BaseLayout
  title="Vidéos"
  description="Sélection de chaînes YouTube et vidéos qui couvrent vraiment Claude Code — Anthropic, IndyDevDan, Cole Medin, Latent Space, Lenny's Podcast."
>
  <PageHero
    eyebrow="05 · Vidéos"
    title="Chaînes & talks curés"
    intro="Une sélection courte de chaînes YouTube, talks et podcasts qui parlent vraiment de Claude Code, des hooks, du MCP et de l'agentic coding — pas des AI-influencers généralistes."
  />

  <section class="mx-auto max-w-6xl px-5 sm:px-8 py-12">
    <VideosCatalog entries={videoEntries} client:load />

    <div
      class="mt-12 rounded-xl border border-claude/20 bg-claude/5 p-6 sm:p-8"
    >
      <p class="font-mono text-xs uppercase tracking-wider text-claude mb-3">
        Filtres de curation
      </p>
      <p class="text-ink leading-relaxed mb-3">
        Pour passer le filtre, une vidéo doit couvrir
        <strong class="text-ink"
          >spécifiquement Claude Code ou l'écosystème immédiat</strong
        > (hooks, MCP, skills, agents SDK, plugins) — pas une simple comparaison
        ChatGPT vs Claude ni une réaction d'AI-influencer.
      </p>
      <p class="text-ink-muted leading-relaxed mb-3">
        Côté <strong class="text-ink">FR</strong> : les chaînes listées sont
        des <strong class="text-ink">recommandations personnelles</strong>
        suivies par l'auteur — pas une couverture exhaustive de l'écosystème
        francophone. Le contenu Claude Code spécifique en FR reste rare ; on
        liste celles qu'on regarde réellement et qui couvrent l'IA dev / le
        coding agentique. Si tu connais une autre chaîne FR sérieuse sur
        Claude Code, ouvre une issue
        <a
          href="https://github.com/Sylad/claude-code-codex/issues"
          target="_blank"
          rel="noopener"
          class="text-claude hover:text-claude-soft underline underline-offset-4"
          >sur le repo</a
        >.
      </p>
    </div>
  </section>
</BaseLayout>
